# Copy to .env and fill in your own values. .env is gitignored.

# Backend API URL. On a physical device (Expo Go or a dev client) use your
# machine's LAN IP, not localhost — the phone can't resolve your computer's
# localhost. Find it with `ipconfig getifaddr en0` (macOS) or `hostname -I`
# (Linux), and keep it updated if your network/IP changes.
EXPO_PUBLIC_API_URL="http://127.0.0.1:8080"
EXPO_PUBLIC_ENV="development"
