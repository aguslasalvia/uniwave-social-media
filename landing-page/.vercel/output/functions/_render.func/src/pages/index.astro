---
import MainLayout from "../layouts/MainLayout.astro";
import Features from "../components/Features.astro";
import Footer from "../components/Footer.astro";
import FAQ from "../components/FAQ.astro";
---

<MainLayout>
	<!-- Hero -->
	<section id="hero">
		<div class="hero-container">
			<div class="hero-content">
				<span class="hero-badge">La comunidad universitaria que necesitabas</span>
				<h1>
					Conecta con tus compañeros, comparte experiencias y descubre todo lo
					que pasa en tu universidad.
				</h1>
				<p>
					Investiga, Comparte, Únete y en especial <strong>Diviértete</strong>
				</p>
				<div class="hero-actions">
					<a class="cta-button" href="#download">
						Descargar App
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M5 12h14M12 5l7 7-7 7"/>
						</svg>
					</a>
				</div>
			</div>
			<figure class="hero-image">
				<div class="phone-frame">
					<img src="/examples/example1.jpg" alt="UniWave App" />
				</div>
				<div class="floating-element element-1"></div>
				<div class="floating-element element-2"></div>
			</figure>
		</div>
	</section>
	<div class="scroll-indicator">
		<a href="#features">
			<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M12 5v14M5 12l7 7 7-7"/>
			</svg>
		</a>
		<span>Descubre más</span>
	</div>
	<div class="section-divider"></div>

	<!-- Features -->
	<Features />
	<div class="section-divider"></div>

	<!-- CTA Section -->
	<section id="download">
		<div class="cta-content">
			<h2>¿Listo para empezar?</h2>
			<p>Únete a miles de estudiantes que ya están usando UniWave</p>
			<div class="cta-buttons">
				<a href="#" class="store-button android-store">
					<div class="store-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path
								d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"
							></path>
						</svg>
					</div>
					<div class="store-text">
						<span class="store-label">Disponible en</span>
						<span class="store-name">Google Play</span>
					</div>
				</a>
				<a href="#" class="store-button apple-store disabled">
					<div class="store-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path
								d="M18.71,19.5C17.88,20.74 17,21.95 15.66,21.97C14.32,22 13.89,21.18 12.37,21.18C10.84,21.18 10.37,21.95 9.1,22C7.79,22.05 6.8,20.68 5.96,19.47C4.25,17 2.94,12.45 4.7,9.39C5.57,7.87 7.13,6.91 8.82,6.88C10.1,6.86 11.32,7.75 12.11,7.75C12.89,7.75 14.37,6.68 15.92,6.84C16.57,6.87 18.39,7.1 19.56,8.82C19.47,8.88 17.39,10.1 17.41,12.63C17.44,15.65 20.06,16.66 20.09,16.67C20.06,16.74 19.67,18.11 18.71,19.5M13,3.5C13.73,2.67 14.94,2.04 15.94,2C16.07,3.17 15.6,4.35 14.9,5.19C14.21,6.04 13.07,6.7 11.95,6.61C11.8,5.46 12.36,4.26 13,3.5Z"
							></path>
						</svg>
					</div>
					<div class="store-text">
						<span class="store-label">Próximamente en</span>
						<span class="store-name">App Store</span>
					</div>
				</a>
			</div>
		</div>
	</section>

	<div class="section-divider"></div>

	<!-- Contact Section -->
	<section id="contact">
		<div class="contact-content">
			<h2>¿Quieres aportar a este proyecto?</h2>
			<p>Dinos tus ideas y sugerencias para mejorar UniWave.</p>
			<div class="contact-info">
				<div class="contact-email">
					<div class="email-icon">💡</div>
					<div class="email-details">
						<h3>Envíanos tus ideas</h3>
						<p>bandicoot.solutions@gmail.com</p>
					</div>
				</div>
				<a href="mailto:bandicoot.solutions@gmail.com" class="contact-button">
					Compartir Ideas
				</a>
			</div>
		</div>
	</section>

	<div class="section-divider"></div>
	<FAQ/>
	<div class="section-divider"></div>
	<!-- Footer -->

	<Footer />
</MainLayout>

<style>
	/* Hero */
	#hero {
		width: 100%;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 8rem 5% 4rem;
		position: relative;
		overflow: hidden;
	}

	#hero::before {
		content: '';
		position: absolute;
		top: -50%;
		right: -20%;
		width: 600px;
		height: 600px;
		background: radial-gradient(circle, rgba(129, 140, 248, 0.15) 0%, transparent 70%);
		border-radius: 50%;
		pointer-events: none;
	}

	.hero-container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
		max-width: 1400px;
		width: 100%;
	}

	.hero-badge {
		display: inline-block;
		background: rgba(129, 140, 248, 0.15);
		color: var(--primary-color);
		padding: 0.5rem 1rem;
		border-radius: 50px;
		font-size: 0.85rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		border: 1px solid rgba(129, 140, 248, 0.3);
	}

	.hero-content h1 {
		color: var(--text-color);
		font-size: 3rem;
		line-height: 1.2;
		margin: 0 0 1.5rem 0;
		font-weight: 800;
		letter-spacing: -1px;
	}

	.hero-content p {
		color: rgba(249, 250, 251, 0.75);
		font-size: 1.25rem;
		margin-bottom: 2rem;
		line-height: 1.6;
	}

	.hero-content strong {
		color: var(--primary-color);
		font-weight: 700;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
	}

	.cta-button {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		background: linear-gradient(135deg, #818cf8, #6366f1);
		color: white;
		border: none;
		padding: 1rem 2rem;
		border-radius: 50px;
		font-size: 1.1rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.3s ease;
		text-decoration: none;
		box-shadow: 0 4px 20px rgba(129, 140, 248, 0.4);
	}

	.cta-button:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 30px rgba(129, 140, 248, 0.5);
		background: linear-gradient(135deg, #a5b4fc, #818cf8);
	}

	.cta-button svg {
		transition: transform 0.3s ease;
	}

	.cta-button:hover svg {
		transform: translateX(4px);
	}

	.hero-image {
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
	}

	.phone-frame {
		position: relative;
		border-radius: 40px;
		padding: 12px;
		background: linear-gradient(145deg, rgba(129, 140, 248, 0.3), rgba(99, 102, 241, 0.2));
		box-shadow: 
			0 25px 50px rgba(0, 0, 0, 0.4),
			0 0 80px rgba(129, 140, 248, 0.2),
			inset 0 0 0 2px rgba(255, 255, 255, 0.1);
		animation: floatPhone 4s ease-in-out infinite;
	}

	.phone-frame img {
		width: 280px;
		border-radius: 32px;
		display: block;
	}

	.floating-element {
		position: absolute;
		border-radius: 50%;
		pointer-events: none;
	}

	.element-1 {
		width: 120px;
		height: 120px;
		background: linear-gradient(135deg, rgba(129, 140, 248, 0.3), rgba(165, 180, 252, 0.1));
		top: -20px;
		right: 10px;
		animation: floatElement1 5s ease-in-out infinite;
	}

	.element-2 {
		width: 80px;
		height: 80px;
		background: linear-gradient(135deg, rgba(165, 180, 252, 0.2), rgba(129, 140, 248, 0.1));
		bottom: 20px;
		left: -20px;
		animation: floatElement2 6s ease-in-out infinite;
	}

	@keyframes floatPhone {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-20px); }
	}

	@keyframes floatElement1 {
		0%, 100% { transform: translate(0, 0) scale(1); }
		50% { transform: translate(10px, -15px) scale(1.1); }
	}

	@keyframes floatElement2 {
		0%, 100% { transform: translate(0, 0) scale(1); }
		50% { transform: translate(-10px, 10px) scale(1.05); }
	}

	.scroll-indicator {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		font-family: sans-serif;
		font-size: 0.9rem;
		color: rgba(249, 250, 251, 0.5);
		cursor: pointer;
		padding-bottom: 3rem;
	}

	.scroll-indicator a {
		color: var(--primary-color);
		animation: bounce 2s infinite;
	}

	@keyframes bounce {
		0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
		40% { transform: translateY(8px); }
		60% { transform: translateY(4px); }
	}

	/* CTA Section */
	#download {
		background: linear-gradient(180deg, var(--bg-color) 0%, rgba(129, 140, 248, 0.05) 100%);
		padding: 8rem 2rem;
		text-align: center;
		margin: 4rem 0;
		position: relative;
	}

	#download::before {
		content: '';
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 200px;
		height: 4px;
		background: linear-gradient(90deg, transparent, var(--primary-color), transparent);
		border-radius: 2px;
	}

	h2 {
		color: var(--text-color);
		font-size: 2.5rem;
		margin: 0 0 1rem 0;
		font-weight: 700;
		letter-spacing: -0.5px;
	}

	.cta-content p {
		color: rgba(249, 250, 251, 0.75);
		font-size: 1.2rem;
		margin-bottom: 2.5rem;
	}

	.cta-buttons {
		display: flex;
		gap: 1.5rem;
		justify-content: center;
		flex-wrap: wrap;
		align-items: center;
	}

	.store-button {
		display: flex;
		align-items: center;
		gap: 1rem;
		background: linear-gradient(135deg, #818cf8, #6366f1);
		color: white;
		text-decoration: none;
		padding: 1rem 2rem;
		border-radius: 16px;
		transition: all 0.3s ease;
		min-width: 240px;
		border: none;
		box-shadow: 0 4px 20px rgba(129, 140, 248, 0.3);
	}

	.store-button:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 35px rgba(129, 140, 248, 0.4);
		background: linear-gradient(135deg, #a5b4fc, #818cf8);
	}

	.store-button.disabled {
		opacity: 0.6;
		cursor: not-allowed;
		background: rgba(249, 250, 251, 0.1);
		border: 1px solid rgba(249, 250, 251, 0.2);
		color: rgba(249, 250, 251, 0.6);
		box-shadow: none;
	}

	.store-button.disabled:hover {
		transform: none;
		box-shadow: none;
	}

	.store-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
	}

	.store-icon svg {
		width: 28px;
		height: 24px;
	}

	.android-store .store-icon {
		color: white;
	}

	.apple-store .store-icon {
		color: white;
	}

	.store-text {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.store-label {
		font-size: 0.75rem;
		color: rgba(255, 255, 255, 0.8);
		margin-bottom: 0.25rem;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.store-name {
		font-size: 1.1rem;
		font-weight: 600;
		color: white;
	}

	/* Contact Section */
	#contact {
		background: linear-gradient(180deg, rgba(129, 140, 248, 0.03) 0%, var(--bg-color) 100%);
		padding: 8rem 2rem;
		text-align: center;
		margin: 4rem 0;
	}

	.contact-content p {
		color: rgba(249, 250, 251, 0.7);
		font-size: 1.2rem;
		margin: 0 0 3rem 0;
	}

	.contact-info {
		max-width: 600px;
		margin: 0 auto;
		text-align: center;
	}

	.contact-email {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
		margin-bottom: 2rem;
		padding: 2rem;
		background: rgba(255, 255, 255, 0.03);
		border-radius: 20px;
		border: 1px solid rgba(129, 140, 248, 0.15);
		transition: all 0.3s ease;
	}

	.contact-email:hover {
		background: rgba(129, 140, 248, 0.08);
		border-color: rgba(129, 140, 248, 0.3);
		transform: translateY(-2px);
	}

	.email-icon {
		font-size: 2rem;
		width: 56px;
		height: 56px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, #818cf8, #6366f1);
		border-radius: 16px;
		color: white;
		box-shadow: 0 4px 15px rgba(129, 140, 248, 0.3);
	}

	.email-details h3 {
		color: var(--text-color);
		font-size: 1.1rem;
		margin: 0 0 0.5rem 0;
		font-weight: 600;
	}

	.email-details p {
		color: var(--primary-color);
		margin: 0;
		font-size: 1rem;
		font-weight: 500;
	}

	.contact-button {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		background: linear-gradient(135deg, #818cf8, #6366f1);
		color: white;
		text-decoration: none;
		padding: 1rem 2.5rem;
		border-radius: 50px;
		font-size: 1rem;
		font-weight: 600;
		transition: all 0.3s ease;
		box-shadow: 0 4px 20px rgba(129, 140, 248, 0.3);
	}
		transition: all 0.3s ease;
		border: 2px solid var(--primary-color);
	}

	.contact-button:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 25px rgba(129, 140, 248, 0.4);
		background: linear-gradient(135deg, #a5b4fc, #818cf8);
	}

	.scroll-indicator {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		font-family: sans-serif;
		font-size: 0.9rem;
		color: rgba(249, 250, 251, 0.5);
		cursor: pointer;
		padding-bottom: 3rem;
	}

	.scroll-indicator span {
		font-size: 0.9rem;
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.hero-container {
			grid-template-columns: 1fr;
			gap: 3rem;
			text-align: center;
		}

		.hero-content h1 {
			font-size: 2.5rem;
		}

		.hero-actions {
			justify-content: center;
		}

		.hero-image {
			order: -1;
		}
	}

	@media (max-width: 768px) {
		.scroll-indicator {
			display: none;
		}

		#hero {
			padding: 7rem 1.5rem 3rem;
			min-height: auto;
		}

		.hero-content h1 {
			font-size: 2rem;
			letter-spacing: -0.5px;
		}

		.hero-content p {
			font-size: 1.1rem;
		}

		.hero-badge {
			font-size: 0.75rem;
		}

		.cta-buttons {
			flex-direction: column;
			align-items: center;
			gap: 1rem;
		}

		.store-button {
			width: 100%;
			max-width: 300px;
			justify-content: center;
		}

		#download {
			padding: 6rem 1.5rem;
		}

		#contact {
			padding: 6rem 1.5rem;
		}

		.contact-email {
			padding: 1.5rem;
			flex-direction: column;
			gap: 1rem;
			text-align: center;
		}
	}

	@media (max-width: 480px) {
		.hero-content h1 {
			font-size: 1.75rem;
		}

		.hero-content p {
			font-size: 1rem;
		}

		.phone-frame img {
			width: 220px;
		}

		.cta-button {
			padding: 0.875rem 1.5rem;
			font-size: 1rem;
		}

		h2 {
			font-size: 1.75rem;
		}
	}

	.section-divider {
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(129, 140, 248, 0.2), transparent);
		margin: 0 auto;
		max-width: 800px;
	}
</style>
