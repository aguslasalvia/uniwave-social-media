---
import MainLayout from "../layouts/MainLayout.astro";
import Features from "../components/Features.astro";
import Footer from "../components/Footer.astro";
import FAQ from "../components/FAQ.astro";
---

<MainLayout>
	<!-- Hero -->
	<section id="hero">
		<div class="hero-container">
			<div class="hero-content">
				<span class="stamp">Hecha por estudiantes, para estudiantes</span>
				<h1>
					Toda tu facu,<br />
					en <span class="mark">una sola app</span>.
				</h1>
				<p>
					Compartí momentos, encontrá tu grupo y enterate de todo lo que
					pasa en el campus. Gratis, para todos los estudiantes.
				</p>
				<div class="hero-actions">
					<a class="cta-primary" href="#download">
						Descargar gratis
						<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
							<path d="M5 12h14M12 5l7 7-7 7"/>
						</svg>
					</a>
					<a class="cta-ghost" href="#features">
						Ver funciones
					</a>
				</div>
				<div class="hero-chips">
					<span class="chip">
						<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
							<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
							<line x1="12" y1="18" x2="12.01" y2="18"/>
						</svg>
						Android
					</span>
					<span class="chip">
						<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
							<path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
							<path d="M6 12v5c3 3 9 3 12 0v-5"/>
						</svg>
						Todas las universidades
					</span>
					<span class="chip">iOS próximamente</span>
				</div>
			</div>

			<figure class="hero-visual">
				<div class="phone-wrapper">
					<div class="phone-glow" aria-hidden="true"></div>
					<div class="phone-frame">
						<img src="/examples/example3.jpg" alt="UniWave — el feed de publicaciones" />
					</div>
				</div>
			</figure>
		</div>
	</section>

	<!-- Features -->
	<Features />

	<!-- CTA / Download -->
	<section id="download">
		<div class="download-content">
			<span class="stamp stamp-night">Disponible ahora</span>
			<h2>Descargá UniWave<br/>y sumate a la movida</h2>
			<p>Gratis para Android. iOS próximamente.</p>
			<div class="store-buttons">
				<a href="#" class="store-btn android">
					<svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
						<path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/>
					</svg>
					<div class="store-text">
						<span class="store-label">Disponible en</span>
						<span class="store-name">Google Play</span>
					</div>
				</a>
				<a href="#" class="store-btn apple disabled" aria-disabled="true">
					<svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
						<path d="M18.71,19.5C17.88,20.74 17,21.95 15.66,21.97C14.32,22 13.89,21.18 12.37,21.18C10.84,21.18 10.37,21.95 9.1,22C7.79,22.05 6.8,20.68 5.96,19.47C4.25,17 2.94,12.45 4.7,9.39C5.57,7.87 7.13,6.91 8.82,6.88C10.1,6.86 11.32,7.75 12.11,7.75C12.89,7.75 14.37,6.68 15.92,6.84C16.57,6.87 18.39,7.1 19.56,8.82C19.47,8.88 17.39,10.1 17.41,12.63C17.44,15.65 20.06,16.66 20.09,16.67C20.06,16.74 19.67,18.11 18.71,19.5M13,3.5C13.73,2.67 14.94,2.04 15.94,2C16.07,3.17 15.6,4.35 14.9,5.19C14.21,6.04 13.07,6.7 11.95,6.61C11.8,5.46 12.36,4.26 13,3.5Z"/>
					</svg>
					<div class="store-text">
						<span class="store-label">Próximamente en</span>
						<span class="store-name">App Store</span>
					</div>
				</a>
			</div>
		</div>
	</section>

	<!-- Contact -->
	<section id="contact">
		<div class="contact-content">
			<span class="stamp">Sumate al proyecto</span>
			<h2>¿Tenés ideas? Escribinos</h2>
			<p>Nos encanta escuchar a la comunidad. Mandanos tus sugerencias y las tenemos en cuenta.</p>
			<a href="mailto:contact@aguslasalvia.online" class="contact-btn">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
					<polyline points="22,6 12,13 2,6"/>
				</svg>
				Escribinos
			</a>
			<p class="contact-email">contact@aguslasalvia.online</p>
		</div>
	</section>

	<FAQ />

	<Footer />
</MainLayout>

<style>
	/* ── Hero ─────────────────────────────────── */
	#hero {
		width: 100%;
		min-height: 92svh;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 7.5rem 5% 3rem;
		background:
			radial-gradient(ellipse 55% 60% at 85% 12%, rgba(99, 102, 241, 0.14) 0%, transparent 70%),
			var(--bg-color);
	}

	.hero-container {
		display: grid;
		grid-template-columns: 1.15fr 0.85fr;
		gap: 4rem;
		align-items: center;
		max-width: 1120px;
		width: 100%;
	}

	.hero-content .stamp {
		margin-bottom: 1.75rem;
	}

	.hero-content h1 {
		font-size: clamp(2.5rem, 5.5vw, 4.25rem);
		line-height: 1.06;
		margin: 0 0 1.5rem 0;
		font-weight: 800;
		letter-spacing: -0.03em;
		color: var(--text-color);
	}

	.hero-content p {
		font-size: 1.125rem;
		color: var(--text-muted);
		margin: 0 0 2.25rem 0;
		line-height: 1.7;
		max-width: 460px;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		align-items: center;
		flex-wrap: wrap;
		margin-bottom: 2rem;
	}

	.cta-primary {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		background: var(--text-color);
		color: var(--bg-color);
		text-decoration: none;
		padding: 0.925rem 1.875rem;
		border-radius: 12px;
		font-size: 1rem;
		font-weight: 600;
		box-shadow: 4px 4px 0 var(--primary-dark);
		transition: transform 0.22s ease, box-shadow 0.22s ease;
	}

	.cta-primary:hover {
		transform: translate(-2px, -2px);
		box-shadow: 7px 7px 0 var(--primary-dark);
	}

	.cta-primary svg {
		transition: transform 0.25s ease;
		flex-shrink: 0;
	}

	.cta-primary:hover svg {
		transform: translateX(4px);
	}

	.cta-ghost {
		display: inline-flex;
		align-items: center;
		color: var(--text-color);
		text-decoration: none;
		font-size: 0.975rem;
		font-weight: 600;
		padding: 0.925rem 1.5rem;
		border-radius: 12px;
		border: 1.5px solid rgba(129, 140, 248, 0.25);
		background: transparent;
		transition: border-color 0.25s ease, background 0.25s ease;
	}

	.cta-ghost:hover {
		border-color: var(--border-hover);
		background: rgba(255, 255, 255, 0.05);
	}

	.hero-chips {
		display: flex;
		gap: 0.625rem;
		flex-wrap: wrap;
	}

	.chip {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		background: var(--card-bg);
		border: 1px solid var(--border-color);
		color: var(--text-muted);
		font-size: 0.78rem;
		font-weight: 500;
		padding: 0.38rem 0.825rem;
		border-radius: 50px;
	}

	.chip svg {
		color: var(--primary-light);
		flex-shrink: 0;
	}

	/* Phone visual */
	.hero-visual {
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0;
	}

	.phone-wrapper {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.phone-glow {
		position: absolute;
		width: 260px;
		height: 260px;
		background: radial-gradient(circle, rgba(99, 102, 241, 0.22) 0%, transparent 68%);
		border-radius: 50%;
		animation: glow-pulse 5s ease-in-out infinite;
	}

	@keyframes glow-pulse {
		0%, 100% { transform: scale(1); opacity: 1; }
		50% { transform: scale(1.12); opacity: 0.65; }
	}

	.phone-frame {
		position: relative;
		border-radius: 36px;
		padding: 10px;
		background: linear-gradient(145deg, rgba(129, 140, 248, 0.22), rgba(99, 102, 241, 0.12));
		box-shadow:
			0 32px 64px rgba(0, 0, 0, 0.55),
			0 0 80px rgba(99, 102, 241, 0.12),
			inset 0 0 0 1px rgba(255, 255, 255, 0.1);
		animation: float-phone 5.5s ease-in-out infinite;
		z-index: 1;
	}

	.phone-frame img {
		width: 180px;
		border-radius: 28px;
		display: block;
	}

	@keyframes float-phone {
		0%, 100% { transform: translateY(0) rotate(-1deg); }
		50% { transform: translateY(-20px) rotate(1deg); }
	}


	/* ── Download band ────────────────────────── */
	#download {
		padding: 4.5rem 2rem 5.5rem;
		background:
			radial-gradient(ellipse 60% 80% at 50% 20%, rgba(255, 255, 255, 0.08) 0%, transparent 70%),
			var(--primary-dark);
		text-align: center;
	}

	.stamp-night {
		color: #fff;
		border-color: rgba(255, 255, 255, 0.45);
	}

	.download-content {
		max-width: 620px;
		margin: 0 auto;
	}

	#download h2 {
		font-size: clamp(2rem, 4vw, 2.9rem);
		margin: 1.5rem 0 1rem;
		font-weight: 800;
		letter-spacing: -0.02em;
		color: #fff;
		line-height: 1.12;
	}

	.download-content > p {
		color: rgba(255, 255, 255, 0.78);
		font-size: 1.1rem;
		margin: 0 0 2.75rem 0;
		line-height: 1.7;
	}

	.store-buttons {
		display: flex;
		gap: 1.25rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.store-btn {
		display: flex;
		align-items: center;
		gap: 1rem;
		background: var(--text-color);
		color: var(--bg-color);
		text-decoration: none;
		padding: 1rem 1.75rem;
		border-radius: 14px;
		min-width: 220px;
		box-shadow: 4px 4px 0 var(--bg-secondary);
		transition: transform 0.22s ease, box-shadow 0.22s ease;
	}

	.store-btn:hover {
		transform: translate(-2px, -2px);
		box-shadow: 7px 7px 0 var(--bg-secondary);
	}

	.store-btn.disabled {
		background: transparent;
		border: 1.5px solid rgba(255, 255, 255, 0.35);
		color: rgba(255, 255, 255, 0.65);
		box-shadow: none;
		cursor: default;
		pointer-events: none;
	}

	.store-text {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.store-label {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		opacity: 0.8;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 0.15rem;
	}

	.store-name {
		font-size: 1.05rem;
		font-weight: 700;
	}

	/* ── Contact ──────────────────────────────── */
	#contact {
		padding: 6.5rem 2rem;
		text-align: center;
	}

	.contact-content {
		max-width: 560px;
		margin: 0 auto;
	}

	#contact h2 {
		font-size: clamp(1.85rem, 3.5vw, 2.6rem);
		margin: 1.5rem 0 1rem;
		font-weight: 800;
		letter-spacing: -0.02em;
		color: var(--text-color);
		line-height: 1.15;
	}

	.contact-content > p {
		color: var(--text-muted);
		font-size: 1.1rem;
		margin: 0 0 2.5rem 0;
		line-height: 1.7;
	}

	.contact-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		background: var(--text-color);
		color: var(--bg-color);
		text-decoration: none;
		padding: 0.925rem 1.875rem;
		border-radius: 12px;
		font-size: 1rem;
		font-weight: 600;
		box-shadow: 4px 4px 0 var(--primary-dark);
		transition: transform 0.22s ease, box-shadow 0.22s ease;
	}

	.contact-btn:hover {
		transform: translate(-2px, -2px);
		box-shadow: 7px 7px 0 var(--primary-dark);
	}

	.contact-email {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		color: var(--text-muted);
		margin: 1.5rem 0 0;
	}

	/* ── Responsive ───────────────────────────── */
	@media (max-width: 1024px) {
		.hero-container {
			grid-template-columns: 1fr;
			text-align: center;
			gap: 3.5rem;
		}

		.hero-content p {
			margin-left: auto;
			margin-right: auto;
		}

		.hero-actions {
			justify-content: center;
		}

		.hero-chips {
			justify-content: center;
		}

		.hero-visual {
			order: -1;
			padding-top: 1rem;
		}
	}

	@media (max-width: 768px) {
		#hero {
			padding: 7rem 1.5rem 3rem;
			min-height: auto;
		}

		.phone-frame img {
			width: 150px;
		}

		.phone-glow {
			width: 220px;
			height: 220px;
		}

		#download {
			padding: 3.5rem 1.5rem 4.5rem;
		}

		#contact {
			padding: 5rem 1.5rem;
		}

		.store-btn {
			min-width: 200px;
			justify-content: center;
		}
	}

	@media (max-width: 480px) {
		.store-buttons {
			flex-direction: column;
			align-items: center;
		}

		.store-btn {
			width: 100%;
			max-width: 300px;
		}


		.contact-email {
			font-size: 0.75rem;
			word-break: break-all;
		}
	}
</style>
