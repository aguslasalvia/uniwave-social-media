---
const faqs = [
	{
		question: "¿Qué es UniWave?",
		answer: "UniWave es una aplicación diseñada para ayudar a los estudiantes a conectarse con sus compañeros, compartir experiencias y descubrir todo lo que está sucediendo en su universidad."
	},
	{
		question: "¿Cómo puedo descargar la aplicación?",
		answer: "Puedes descargar UniWave directamente desde Google Play (para dispositivos Android). La versión para iOS estará disponible próximamente en la App Store."
	},
	{
		question: "¿Es UniWave gratuita?",
		answer: "Sí, UniWave es completamente gratuita para todos los estudiantes. No tendrás que pagar nada para descargarla y usar sus funciones."
	},
	{
		question: "¿En qué universidades está disponible UniWave?",
		answer: "UniWave está disponible para estudiantes de todas las universidades. Si tu universidad aún no está en la plataforma, puedes sugerirla a través del correo electrónico de contacto."
	},
	{
		question: "¿Puedo sugerir una nueva función para la app?",
		answer: "Sí, nos encantaría recibir tus sugerencias. Puedes enviarlas por correo electrónico a bandicoot.solutions@gmail.com."
	},
	{
		question: "¿Quién es Bandicoot Solutions?",
		answer: "En Bandicoot creemos en el poder de las ideas simples que generan grandes resultados. Somos dos desarrolladores apasionados por la programación, construyendo soluciones tecnológicas con visión de futuro. Descubrí más en nuestra Landing Page oficial."
	}
];
---

<section id="faq">
	<div class="faq-container">
		<div class="faq-header">
			<span class="section-tag">FAQ</span>
			<h2>Preguntas Frecuentes</h2>
			<p>Todo lo que necesitas saber sobre UniWave</p>
		</div>
		
		<div class="faq-grid">
			{
				faqs.map((faq, index) => (
					<details class="faq-item" style={`--delay: ${index * 0.1}s`}>
						<summary>
							<span class="faq-number">{(index + 1).toString().padStart(2, '0')}</span>
							<span class="faq-question">{faq.question}</span>
							<svg class="faq-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M12 5v14M5 12l7 7 7-7"/>
							</svg>
						</summary>
						<p>{faq.answer}</p>
					</details>
				))
			}
		</div>
	</div>
</section>

<style>
	#faq {
		background: var(--bg-color);
		padding: 8rem 2rem;
	}

	.faq-container {
		max-width: 800px;
		margin: 0 auto;
	}

	.faq-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.section-tag {
		display: inline-block;
		background: rgba(129, 140, 248, 0.15);
		color: var(--primary-color);
		padding: 0.5rem 1.25rem;
		border-radius: 50px;
		font-size: 0.85rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		border: 1px solid rgba(129, 140, 248, 0.3);
	}

	.faq-header h2 {
		color: var(--text-color);
		font-size: 2.5rem;
		margin: 0 0 1rem 0;
		font-weight: 700;
		letter-spacing: -0.5px;
	}

	.faq-header p {
		color: rgba(249, 250, 251, 0.7);
		font-size: 1.15rem;
		margin: 0;
	}

	.faq-grid {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.faq-item {
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(129, 140, 248, 0.1);
		border-radius: 16px;
		overflow: hidden;
		transition: all 0.3s ease;
	}

	.faq-item:hover {
		background: rgba(129, 140, 248, 0.05);
		border-color: rgba(129, 140, 248, 0.2);
	}

	.faq-item summary {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1.5rem;
		cursor: pointer;
		list-style: none;
		outline: none;
	}

	.faq-item summary::-webkit-details-marker {
		display: none;
	}

	.faq-number {
		font-size: 1.5rem;
		font-weight: 800;
		color: var(--primary-color);
		opacity: 0.5;
	}

	.faq-question {
		flex: 1;
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--text-color);
		text-align: left;
	}

	.faq-icon {
		color: var(--primary-color);
		transition: transform 0.3s ease;
		flex-shrink: 0;
	}

	.faq-item[open] .faq-icon {
		transform: rotate(180deg);
	}

	.faq-item p {
		font-size: 1rem;
		color: rgba(249, 250, 251, 0.75);
		line-height: 1.7;
		padding: 0 1.5rem 1.5rem 4.5rem;
		margin: 0;
	}

	.faq-item a {
		color: var(--primary-color);
		text-decoration: none;
		font-weight: 600;
	}

	.faq-item a:hover {
		text-decoration: underline;
	}

	@media (max-width: 768px) {
		#faq {
			padding: 6rem 1.5rem;
		}

		.faq-header h2 {
			font-size: 2rem;
		}

		.faq-item summary {
			padding: 1.25rem;
			gap: 0.75rem;
		}

		.faq-number {
			font-size: 1.25rem;
		}

		.faq-question {
			font-size: 1rem;
		}

		.faq-item p {
			padding: 0 1.25rem 1.25rem 3.5rem;
			font-size: 0.95rem;
		}
	}
</style>
