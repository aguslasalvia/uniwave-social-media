---
const faqs = [
	{
		question: "¿Qué es UniWave?",
		answer: "UniWave es una aplicación diseñada para ayudar a los estudiantes a conectarse con sus compañeros, compartir experiencias y descubrir todo lo que está sucediendo en su universidad."
	},
	{
		question: "¿Cómo puedo descargar la aplicación?",
		answer: "Podés descargar UniWave directamente desde Google Play (para dispositivos Android). La versión para iOS estará disponible próximamente en la App Store."
	},
	{
		question: "¿Es UniWave gratuita?",
		answer: "Sí, UniWave es completamente gratuita para todos los estudiantes. No vas a tener que pagar nada para descargarla y usar sus funciones."
	},
	{
		question: "¿En qué universidades está disponible UniWave?",
		answer: "UniWave está disponible para estudiantes de todas las universidades. Si tu universidad aún no está en la plataforma, podés sugerirla a través del correo electrónico de contacto."
	},
	{
		question: "¿Puedo sugerir una nueva función para la app?",
		answer: "Sí, nos encantaría recibir tus sugerencias. Podés enviarlas por correo electrónico a contact@aguslasalvia.online."
	},
	{
		question: "¿Quién es Bandicoot Solutions?",
		answer: "En Bandicoot creemos en el poder de las ideas simples que generan grandes resultados. Somos dos desarrolladores apasionados por la programación, construyendo soluciones tecnológicas con visión de futuro."
	}
];
---

<section id="faq">
	<div class="faq-container">
		<div class="faq-header">
			<span class="section-tag">FAQ</span>
			<h2>Preguntas Frecuentes</h2>
			<p>Todo lo que necesitás saber sobre UniWave</p>
		</div>

		<div class="faq-list">
			{faqs.map((faq, index) => (
				<details class="faq-item">
					<summary>
						<span class="faq-num">{(index + 1).toString().padStart(2, '0')}</span>
						<span class="faq-q">{faq.question}</span>
						<svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
							<polyline points="6 9 12 15 18 9"/>
						</svg>
					</summary>
					<div class="faq-body">
						<p>{faq.answer}</p>
					</div>
				</details>
			))}
		</div>
	</div>
</section>

<style>
	#faq {
		padding: 7rem 2rem;
	}

	.faq-container {
		max-width: 760px;
		margin: 0 auto;
	}

	.faq-header {
		text-align: center;
		margin-bottom: 3.5rem;
	}

	.section-tag {
		display: inline-block;
		background: rgba(129, 140, 248, 0.12);
		color: var(--primary-light);
		padding: 0.4rem 1rem;
		border-radius: 50px;
		font-size: 0.8rem;
		font-weight: 600;
		margin-bottom: 1.25rem;
		border: 1px solid rgba(129, 140, 248, 0.22);
	}

	.faq-header h2 {
		color: var(--text-color);
		font-size: clamp(1.75rem, 3.5vw, 2.5rem);
		margin: 0 0 0.875rem 0;
		font-weight: 800;
		letter-spacing: -0.75px;
	}

	.faq-header p {
		color: var(--text-muted);
		font-size: 1.05rem;
		margin: 0;
	}

	.faq-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.faq-item {
		background: var(--card-bg);
		border: 1px solid var(--border-color);
		border-radius: 16px;
		overflow: hidden;
		transition: border-color 0.25s ease, background 0.25s ease;
	}

	.faq-item[open] {
		border-color: rgba(129, 140, 248, 0.25);
		background: rgba(129, 140, 248, 0.04);
	}

	.faq-item summary {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1.375rem 1.5rem;
		cursor: pointer;
		list-style: none;
		outline: none;
		user-select: none;
	}

	.faq-item summary::-webkit-details-marker {
		display: none;
	}

	.faq-item summary:hover .faq-q {
		color: var(--text-color);
	}

	.faq-num {
		font-size: 1.25rem;
		font-weight: 800;
		color: var(--primary-color);
		opacity: 0.4;
		flex-shrink: 0;
		font-variant-numeric: tabular-nums;
		min-width: 2rem;
	}

	.faq-q {
		flex: 1;
		font-size: 1rem;
		font-weight: 600;
		color: rgba(241, 245, 249, 0.9);
		line-height: 1.45;
		transition: color 0.2s ease;
	}

	.faq-chevron {
		color: var(--primary-color);
		flex-shrink: 0;
		opacity: 0.7;
		transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.faq-item[open] .faq-chevron {
		transform: rotate(180deg);
	}

	.faq-body {
		padding: 0 1.5rem 1.375rem 4.25rem;
	}

	.faq-body p {
		font-size: 0.95rem;
		color: var(--text-muted);
		line-height: 1.75;
		margin: 0;
	}

	@media (max-width: 768px) {
		#faq {
			padding: 5rem 1.5rem;
		}

		.faq-item summary {
			padding: 1.25rem;
			gap: 0.75rem;
		}

		.faq-num {
			font-size: 1.1rem;
		}

		.faq-q {
			font-size: 0.95rem;
		}

		.faq-body {
			padding: 0 1.25rem 1.25rem 3.5rem;
		}

		.faq-body p {
			font-size: 0.9rem;
		}
	}
</style>
