---
const features = [
	{
		img: "/examples/example1.jpg",
		emoji: "🔐",
		title: "Iniciar Sesión",
		description: "Accede a tu cuenta de forma segura y rápida",
	},
	{
		img: "/examples/example2.jpg",
		emoji: "📝",
		title: "Registrarse",
		description: "Crea tu cuenta y únete a la comunidad universitaria",
	},
	{
		img: "/examples/example3.jpg",
		emoji: "📱",
		title: "Publicaciones",
		description: "Compartí experiencias, fotos y momentos con tus compañeros",
	},
	{
		img: "/examples/example4.jpg",
		emoji: "👥",
		title: "Grupos y Búsquedas",
		description: "Encontrá y unite a grupos de tu carrera o intereses",
	},
	{
		img: "/examples/example5.jpg",
		emoji: "👤",
		title: "Perfil",
		description: "Personalizá tu perfil y mostrá tu identidad universitaria",
	},
	{
		img: "/examples/example6.jpg",
		emoji: "✏️",
		title: "Editar Perfil",
		description: "Actualizá tu información y mantené tu perfil al día",
	},
];
---

<section id="features">
	<div class="features-header">
		<span class="section-tag">Funcionalidades</span>
		<h2>Todo lo que UniWave tiene para vos</h2>
		<p>Una experiencia diseñada para conectar, compartir y vivir la universidad al máximo</p>
	</div>

	<div class="features-grid">
		{
			features.map((feature) => (
				<div class="feature-card">
					<div class="feature-image">
						<img src={feature.img} alt={feature.title} loading="lazy" />
						<div class="feature-overlay" aria-hidden="true" />
					</div>
					<div class="feature-content">
						<span class="feature-emoji" aria-hidden="true">{feature.emoji}</span>
						<h3>{feature.title}</h3>
						<p>{feature.description}</p>
					</div>
				</div>
			))
		}
	</div>

	<div class="scroll-hint" aria-hidden="true">
		<span></span>
		<span></span>
		<span></span>
	</div>
</section>

<style>
	#features {
		padding: 6rem 2rem;
		max-width: 1300px;
		margin: 0 auto;
		width: 100%;
	}

	.features-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.section-tag {
		display: inline-block;
		background: rgba(129, 140, 248, 0.12);
		color: var(--primary-light);
		padding: 0.4rem 1rem;
		border-radius: 50px;
		font-size: 0.8rem;
		font-weight: 600;
		margin-bottom: 1.25rem;
		border: 1px solid rgba(129, 140, 248, 0.22);
	}

	.features-header h2 {
		color: var(--text-color);
		font-size: clamp(1.75rem, 3.5vw, 2.5rem);
		margin: 0 0 1rem 0;
		font-weight: 800;
		letter-spacing: -0.75px;
	}

	.features-header p {
		color: var(--text-muted);
		font-size: 1.1rem;
		margin: 0 auto;
		max-width: 540px;
		line-height: 1.7;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.feature-card {
		position: relative;
		border-radius: 22px;
		overflow: hidden;
		height: 360px;
		transition: transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.1),
					box-shadow 0.35s ease,
					border-color 0.35s ease;
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		cursor: default;
	}

	.feature-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 24px 48px rgba(99, 102, 241, 0.18);
		border-color: rgba(129, 140, 248, 0.28);
	}

	.feature-image {
		position: absolute;
		inset: 0;
		height: 65%;
		z-index: 1;
	}

	.feature-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.feature-card:hover .feature-image img {
		transform: scale(1.06);
	}

	.feature-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			180deg,
			rgba(8, 12, 24, 0.15) 0%,
			rgba(8, 12, 24, 0.98) 100%
		);
		z-index: 2;
	}

	.feature-content {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 1.75rem;
		z-index: 3;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.feature-emoji {
		font-size: 1.75rem;
		line-height: 1;
		margin-bottom: 0.25rem;
	}

	.feature-content h3 {
		color: var(--text-color);
		font-size: 1.2rem;
		margin: 0;
		font-weight: 700;
		letter-spacing: -0.25px;
	}

	.feature-content p {
		color: rgba(241, 245, 249, 0.65);
		margin: 0;
		font-size: 0.88rem;
		line-height: 1.55;
	}

	/* Scroll hint dots — only show on mobile */
	.scroll-hint {
		display: none;
		justify-content: center;
		gap: 5px;
		margin-top: 1.25rem;
	}

	.scroll-hint span {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--border-hover);
	}

	.scroll-hint span:first-child {
		background: var(--primary-color);
	}

	@media (max-width: 1024px) {
		.features-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		#features {
			padding: 4.5rem 0 4.5rem;
		}

		.features-header {
			padding: 0 1.5rem;
		}

		.features-header h2 {
			font-size: 1.75rem;
		}

		.features-grid {
			display: flex;
			overflow-x: auto;
			scroll-snap-type: x mandatory;
			-webkit-overflow-scrolling: touch;
			gap: 1rem;
			padding: 0.5rem 1.5rem 1.25rem;
			scrollbar-width: none;
			grid-template-columns: unset;
		}

		.features-grid::-webkit-scrollbar {
			display: none;
		}

		.feature-card {
			flex: 0 0 280px;
			scroll-snap-align: start;
			height: 320px;
		}

		.scroll-hint {
			display: flex;
		}
	}

	@media (max-width: 480px) {
		.feature-card {
			flex: 0 0 260px;
		}
	}
</style>
