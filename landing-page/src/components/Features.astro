---
// src/components/Features.astro

const features = [
	{
		img: "/examples/example1.jpg",
		title: "🔐 Iniciar Sesión",
		description: "Accede a tu cuenta de forma segura y rápida",
		// icon: "🔐",
	},
	{
		img: "/examples/example2.jpg",
		title: "📝 Registrarse",
		description: "Crea tu cuenta y únete a la comunidad universitaria",
		// icon: "📝",
	},
	{
		img: "/examples/example3.jpg",
		title: "📱 Publicaciones",
		description: "Comparte experiencias, fotos y momentos con tus compañeros",
		// icon: "📱",
	},
	{
		img: "/examples/example4.jpg",
		title: "👥 Grupos y Búsquedas",
		description: "Encuentra y únete a grupos de tu carrera o intereses",
		// icon: "👥",
	},
	{
		img: "/examples/example5.jpg",
		title: "👤 Perfil",
		description: "Personaliza tu perfil y muestra tu identidad universitaria",
		// icon: "👤",
	},
	{
		img: "/examples/example6.jpg",
		title: "✏️ Editar Perfil",
		description: "Actualiza tu información y mantén tu perfil al día",
		// icon: "✏️",
	},
];
---

<section id="features">
	<div class="features-header">
		<span class="section-tag">Funcionalidades</span>
		<h2>Descubre todo lo que UniWave tiene para ofrecerte</h2>
		<p>Una experiencia diseñada para conectar, compartir y vivir la universidad al máximo</p>
	</div>

	<div class="features-grid">
		{
			features.map((feature, index) => (
				<div class="feature-card" style={`--delay: ${index * 0.1}s`}>
					<div class="feature-image">
						<img src={feature.img} alt={feature.title} />
						<div class="feature-overlay" />
					</div>
					<div class="feature-content">
						<div class="feature-icon">{feature.title.split(' ')[0]}</div>
						<h3>{feature.title.substring(feature.title.indexOf(' ') + 1)}</h3>
						<p>{feature.description}</p>
					</div>
				</div>
			))
		}
	</div>
</section>

<style>
	#features {
		padding: 6rem 2rem;
		max-width: 1400px;
		margin: 0 auto;
	}

	.features-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.section-tag {
		display: inline-block;
		background: rgba(129, 140, 248, 0.15);
		color: var(--primary-color);
		padding: 0.5rem 1.25rem;
		border-radius: 50px;
		font-size: 0.85rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		border: 1px solid rgba(129, 140, 248, 0.3);
	}

	.features-header h2 {
		color: var(--text-color);
		font-size: 2.5rem;
		margin: 0 0 1rem 0;
		font-weight: 700;
		letter-spacing: -0.5px;
	}

	.features-header p {
		color: rgba(249, 250, 251, 0.7);
		font-size: 1.15rem;
		margin: 0;
		max-width: 600px;
		margin: 0 auto;
	}

	.features-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.feature-card {
		position: relative;
		border-radius: 24px;
		overflow: hidden;
		height: 360px;
		transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		cursor: pointer;
		background: var(--bg-color);
		border: 1px solid rgba(129, 140, 248, 0.1);
	}

	.feature-card:hover {
		transform: translateY(-10px);
		box-shadow: 0 25px 50px rgba(129, 140, 248, 0.15);
		border-color: rgba(129, 140, 248, 0.3);
	}

	.feature-image {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 60%;
		z-index: 1;
	}

	.feature-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.feature-card:hover .feature-image img {
		transform: scale(1.1);
	}

	.feature-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(180deg, rgba(17, 24, 39, 0.3) 0%, rgba(17, 24, 39, 0.95) 100%);
		z-index: 2;
	}

	.feature-content {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 2rem;
		z-index: 3;
		height: 100%;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
	}

	.feature-icon {
		font-size: 2rem;
		margin-bottom: 0.5rem;
		filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.5));
	}

	.feature-content h3 {
		color: white;
		font-size: 1.4rem;
		margin: 0 0 0.5rem 0;
		font-weight: 600;
		text-shadow: 0 2px 4px rgba(0, 0, 0, 0.7);
	}
		font-weight: 700;
	}

	.feature-content p {
		color: rgba(255, 255, 255, 0.8);
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.6;
	}

	@media (max-width: 1024px) {
		.features-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.features-header h2 {
			font-size: 2rem;
		}
	}

	@media (max-width: 768px) {
		#features {
			padding: 4rem 1.5rem;
		}

		.features-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.features-header {
			margin-bottom: 3rem;
		}

		.features-header h2 {
			font-size: 1.75rem;
		}

		.features-header p {
			font-size: 1rem;
		}

		.feature-card {
			height: 300px;
		}

		.feature-content {
			padding: 1.5rem;
		}

		.feature-content h3 {
			font-size: 1.3rem;
		}
	}
</style>
