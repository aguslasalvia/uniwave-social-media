---
const links = [
	{ label: "Inicio", href: "/#" },
	{ label: "Funciones", href: "/#features" },
	{ label: "Descargar", href: "/#download" },
	{ label: "Contacto", href: "/#contact" },
	{ label: "FAQ", href: "/#faq" },
];
---

<header>
	<nav>
		<a href="#hero" class="logo">
			<img src="/logo.png" alt="App Logo" />
			<span>UniWave</span>
		</a>

		<ul class="nav-links">
			{
				links.map((link) => (
					<li>
						<a class="nav-link" href={link.href}>
							{link.label}
						</a>
					</li>
				))
			}
		</ul>

		<a class="btn-download" href="#download">
			Descargar
		</a>
	</nav>
</header>

<style>
	header {
		width: 100%;
		background: rgba(17, 24, 39, 0.85);
		backdrop-filter: blur(12px);
		padding: 0.75rem 2rem;
		position: fixed;
		top: 0;
		z-index: 1000;
		border-bottom: 1px solid rgba(129, 140, 248, 0.15);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		gap: 2rem;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
	}

	.logo img {
		width: 40px;
		height: 40px;
		border-radius: 10px;
	}

	.logo span {
		font-size: 1.4rem;
		font-weight: 700;
		color: var(--text-color);
		letter-spacing: -0.5px;
	}

	.nav-links {
		display: flex;
		gap: 2rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.nav-link {
		color: rgba(249, 250, 251, 0.75);
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		transition: all 0.2s ease;
		position: relative;
		padding: 0.5rem 0;
	}

	.nav-link::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		width: 0;
		height: 2px;
		background: var(--primary-color);
		transition: width 0.3s ease;
	}

	.nav-link:hover {
		color: var(--text-color);
	}

	.nav-link:hover::after {
		width: 100%;
	}

	.btn-download {
		background: linear-gradient(135deg, #818cf8, #6366f1);
		color: white;
		padding: 0.65rem 1.5rem;
		border-radius: 50px;
		font-weight: 600;
		font-size: 0.9rem;
		text-decoration: none;
		transition: all 0.3s ease;
		box-shadow: 0 4px 15px rgba(129, 140, 248, 0.3);
	}

	.btn-download:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(129, 140, 248, 0.4);
		background: linear-gradient(135deg, #a5b4fc, #818cf8);
	}

	@media (max-width: 900px) {
		.nav-links {
			display: none;
		}

		.btn-download {
			margin-left: auto;
		}
	}
</style>
