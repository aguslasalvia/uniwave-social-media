---
import "../global.css";
import Navbar from "../components/Navbar.astro";
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="UniWave: la app para conectar con tu universidad. Compartí momentos, encontrá grupos y enterate de todo lo que pasa en tu facu. Gratis para estudiantes."
		/>
		<link rel="icon" href="/logo.png" type="image/png" />
		<link
			href="https://cdn.boxicons.com/fonts/basic/boxicons.min.css"
			rel="stylesheet"
		/>

		<title>UniWave — La red social de tu facu</title>
	</head>
	<body>
		<Navbar />
		<main class="fade-in">
			<slot />
		</main>
	</body>
</html>

<style>
	html {
		background-color: var(--bg-color);
		width: 100%;
	}
	body {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		width: 100%;
	}
	main {
		width: 100%;
	}
</style>
