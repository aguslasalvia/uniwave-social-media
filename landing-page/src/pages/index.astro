---
import MainLayout from "../layouts/MainLayout.astro";
import Features from "../components/Features.astro";
import Footer from "../components/Footer.astro";
import FAQ from "../components/FAQ.astro";
---

<MainLayout>
	<!-- Hero -->
	<section id="hero">
		<div class="hero-bg" aria-hidden="true">
			<div class="mesh-1"></div>
			<div class="mesh-2"></div>
		</div>

		<div class="hero-container">
			<div class="hero-content">
				<div class="hero-badge">
					<span class="badge-dot"></span>
					La comunidad universitaria que necesitabas
				</div>
				<h1>
					Conectá con tu universidad.<br />
					<span class="text-gradient">Viví la experiencia.</span>
				</h1>
				<p>
					Compartí momentos, encontrá grupos y descubrí todo lo que pasa en tu campus. Gratis, para todos los estudiantes.
				</p>
				<div class="hero-actions">
					<a class="cta-primary" href="#download">
						Descargar Gratis
						<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
							<path d="M5 12h14M12 5l7 7-7 7"/>
						</svg>
					</a>
					<a class="cta-ghost" href="#features">
						Ver funciones
					</a>
				</div>
				<div class="hero-pills">
					<span class="pill">
						<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
							<polyline points="20 6 9 17 4 12"/>
						</svg>
						100% Gratuita
					</span>
					<span class="pill">
						<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
							<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
							<line x1="12" y1="18" x2="12.01" y2="18"/>
						</svg>
						Android
					</span>
					<span class="pill">
						<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
							<path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
							<path d="M6 12v5c3 3 9 3 12 0v-5"/>
						</svg>
						Todas las Universidades
					</span>
				</div>
			</div>

			<figure class="hero-visual">
				<div class="phone-wrapper">
					<div class="phone-glow" aria-hidden="true"></div>
					<div class="phone-frame">
						<img src="/examples/example1.jpg" alt="UniWave App - pantalla principal" />
					</div>
				</div>
			</figure>
		</div>

		<a class="scroll-indicator" href="#features" aria-label="Ir a funciones">
			<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M12 5v14M5 12l7 7 7-7"/>
			</svg>
			<span>Descubre más</span>
		</a>
	</section>

	<div class="section-divider"></div>

	<!-- Features -->
	<Features />

	<div class="section-divider"></div>

	<!-- CTA / Download -->
	<section id="download">
		<div class="download-bg" aria-hidden="true"></div>
		<div class="download-content">
			<span class="section-tag">Disponible ahora</span>
			<h2>Descargá UniWave<br/>y sumáte a la comunidad</h2>
			<p>Gratis para Android. iOS próximamente.</p>
			<div class="store-buttons">
				<a href="#" class="store-btn android">
					<svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
						<path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/>
					</svg>
					<div class="store-text">
						<span class="store-label">Disponible en</span>
						<span class="store-name">Google Play</span>
					</div>
				</a>
				<a href="#" class="store-btn apple disabled" aria-disabled="true">
					<svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
						<path d="M18.71,19.5C17.88,20.74 17,21.95 15.66,21.97C14.32,22 13.89,21.18 12.37,21.18C10.84,21.18 10.37,21.95 9.1,22C7.79,22.05 6.8,20.68 5.96,19.47C4.25,17 2.94,12.45 4.7,9.39C5.57,7.87 7.13,6.91 8.82,6.88C10.1,6.86 11.32,7.75 12.11,7.75C12.89,7.75 14.37,6.68 15.92,6.84C16.57,6.87 18.39,7.1 19.56,8.82C19.47,8.88 17.39,10.1 17.41,12.63C17.44,15.65 20.06,16.66 20.09,16.67C20.06,16.74 19.67,18.11 18.71,19.5M13,3.5C13.73,2.67 14.94,2.04 15.94,2C16.07,3.17 15.6,4.35 14.9,5.19C14.21,6.04 13.07,6.7 11.95,6.61C11.8,5.46 12.36,4.26 13,3.5Z"/>
					</svg>
					<div class="store-text">
						<span class="store-label">Próximamente en</span>
						<span class="store-name">App Store</span>
					</div>
				</a>
			</div>
		</div>
	</section>

	<div class="section-divider"></div>

	<!-- Contact -->
	<section id="contact">
		<div class="contact-content">
			<span class="section-tag">Sumate al proyecto</span>
			<h2>¿Querés aportar ideas?</h2>
			<p>Nos encanta escuchar a la comunidad. Mandanos tus sugerencias y las tenemos en cuenta.</p>
			<a href="mailto:contact@aguslasalvia.online" class="contact-card">
				<div class="contact-icon">
					<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
						<polyline points="22,6 12,13 2,6"/>
					</svg>
				</div>
				<div class="contact-info">
					<span class="contact-label">Escribinos a</span>
					<span class="contact-email">contact@aguslasalvia.online</span>
				</div>
				<svg class="contact-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M5 12h14M12 5l7 7-7 7"/>
				</svg>
			</a>
		</div>
	</section>

	<div class="section-divider"></div>

	<FAQ />

	<div class="section-divider"></div>

	<Footer />
</MainLayout>

<style>
	/* ── Hero ─────────────────────────────────── */
	#hero {
		width: 100%;
		min-height: 100svh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 7rem 5% 4rem;
		position: relative;
		overflow: hidden;
		gap: 3rem;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	.mesh-1 {
		position: absolute;
		top: -15%;
		right: -8%;
		width: 65vw;
		height: 65vw;
		max-width: 720px;
		max-height: 720px;
		background: radial-gradient(ellipse, rgba(99, 102, 241, 0.14) 0%, transparent 65%);
		border-radius: 50%;
	}

	.mesh-2 {
		position: absolute;
		bottom: 0;
		left: -12%;
		width: 50vw;
		height: 50vw;
		max-width: 560px;
		max-height: 560px;
		background: radial-gradient(ellipse, rgba(167, 139, 250, 0.08) 0%, transparent 65%);
		border-radius: 50%;
	}

	.hero-container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
		max-width: 1160px;
		width: 100%;
		position: relative;
		z-index: 1;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: rgba(129, 140, 248, 0.1);
		color: var(--primary-light);
		padding: 0.45rem 0.9rem;
		border-radius: 50px;
		font-size: 0.8rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		border: 1px solid rgba(129, 140, 248, 0.22);
		width: fit-content;
		letter-spacing: 0.1px;
	}

	.badge-dot {
		width: 7px;
		height: 7px;
		background: #4ade80;
		border-radius: 50%;
		flex-shrink: 0;
		animation: pulse-dot 2.5s ease-in-out infinite;
	}

	@keyframes pulse-dot {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.55; transform: scale(0.75); }
	}

	.hero-content h1 {
		font-size: clamp(2.1rem, 4.5vw, 3.5rem);
		line-height: 1.14;
		margin: 0 0 1.4rem 0;
		font-weight: 800;
		letter-spacing: -1.5px;
		color: var(--text-color);
	}

	.hero-content p {
		font-size: 1.1rem;
		color: var(--text-muted);
		margin: 0 0 2.25rem 0;
		line-height: 1.75;
		max-width: 440px;
	}

	.hero-actions {
		display: flex;
		gap: 0.875rem;
		align-items: center;
		flex-wrap: wrap;
		margin-bottom: 2.25rem;
	}

	.cta-primary {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
		color: white;
		text-decoration: none;
		padding: 0.875rem 1.875rem;
		border-radius: 50px;
		font-size: 0.975rem;
		font-weight: 600;
		transition: all 0.28s ease;
		box-shadow: 0 4px 24px rgba(99, 102, 241, 0.45);
	}

	.cta-primary:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 32px rgba(99, 102, 241, 0.6);
	}

	.cta-primary svg {
		transition: transform 0.25s ease;
		flex-shrink: 0;
	}

	.cta-primary:hover svg {
		transform: translateX(4px);
	}

	.cta-ghost {
		display: inline-flex;
		align-items: center;
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		padding: 0.875rem 1.375rem;
		border-radius: 50px;
		border: 1px solid var(--border-color);
		transition: all 0.25s ease;
	}

	.cta-ghost:hover {
		color: var(--text-color);
		border-color: var(--border-hover);
		background: rgba(255, 255, 255, 0.04);
	}

	.hero-pills {
		display: flex;
		gap: 0.625rem;
		flex-wrap: wrap;
	}

	.pill {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.07);
		color: var(--text-muted);
		font-size: 0.78rem;
		font-weight: 500;
		padding: 0.38rem 0.825rem;
		border-radius: 50px;
	}

	.pill svg {
		color: var(--primary-light);
		flex-shrink: 0;
	}

	/* Phone visual */
	.hero-visual {
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		margin: 0;
	}

	.phone-wrapper {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.phone-glow {
		position: absolute;
		width: 260px;
		height: 260px;
		background: radial-gradient(circle, rgba(99, 102, 241, 0.22) 0%, transparent 68%);
		border-radius: 50%;
		animation: glow-pulse 5s ease-in-out infinite;
	}

	@keyframes glow-pulse {
		0%, 100% { transform: scale(1); opacity: 1; }
		50% { transform: scale(1.12); opacity: 0.65; }
	}

	.phone-frame {
		position: relative;
		border-radius: 36px;
		padding: 10px;
		background: linear-gradient(145deg, rgba(129, 140, 248, 0.22), rgba(99, 102, 241, 0.12));
		box-shadow:
			0 32px 64px rgba(0, 0, 0, 0.55),
			0 0 80px rgba(99, 102, 241, 0.12),
			inset 0 0 0 1px rgba(255, 255, 255, 0.1);
		animation: float-phone 5.5s ease-in-out infinite;
		z-index: 1;
	}

	.phone-frame img {
		width: 200px;
		border-radius: 28px;
		display: block;
	}

	@keyframes float-phone {
		0%, 100% { transform: translateY(0) rotate(-1deg); }
		50% { transform: translateY(-20px) rotate(1deg); }
	}

	/* Scroll indicator */
	.scroll-indicator {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.4rem;
		color: rgba(241, 245, 249, 0.35);
		font-size: 0.8rem;
		font-weight: 500;
		text-decoration: none;
		position: relative;
		z-index: 1;
		transition: color 0.2s ease;
		letter-spacing: 0.5px;
	}

	.scroll-indicator:hover {
		color: var(--primary-light);
	}

	.scroll-indicator svg {
		animation: bounce-arrow 2.2s ease-in-out infinite;
		color: var(--primary-color);
		opacity: 0.7;
	}

	@keyframes bounce-arrow {
		0%, 100% { transform: translateY(0); }
		45% { transform: translateY(7px); }
		65% { transform: translateY(3px); }
	}

	/* ── Download ─────────────────────────────── */
	#download {
		padding: 7rem 2rem;
		position: relative;
		overflow: hidden;
		text-align: center;
	}

	.download-bg {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse 60% 80% at 50% 50%, rgba(99, 102, 241, 0.08) 0%, transparent 70%);
		pointer-events: none;
	}

	.download-content {
		position: relative;
		z-index: 1;
		max-width: 620px;
		margin: 0 auto;
	}

	.section-tag {
		display: inline-block;
		background: rgba(129, 140, 248, 0.12);
		color: var(--primary-light);
		padding: 0.4rem 1rem;
		border-radius: 50px;
		font-size: 0.8rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		border: 1px solid rgba(129, 140, 248, 0.22);
		letter-spacing: 0.2px;
	}

	#download h2,
	#contact h2 {
		font-size: clamp(1.9rem, 4vw, 2.75rem);
		margin: 0 0 1rem 0;
		font-weight: 800;
		letter-spacing: -1px;
		color: var(--text-color);
		line-height: 1.15;
	}

	.download-content > p,
	.contact-content > p {
		color: var(--text-muted);
		font-size: 1.1rem;
		margin: 0 0 2.75rem 0;
		line-height: 1.7;
	}

	.store-buttons {
		display: flex;
		gap: 1.25rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.store-btn {
		display: flex;
		align-items: center;
		gap: 1rem;
		background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
		color: white;
		text-decoration: none;
		padding: 1rem 1.75rem;
		border-radius: 18px;
		min-width: 220px;
		transition: all 0.28s ease;
		box-shadow: 0 4px 24px rgba(99, 102, 241, 0.35);
	}

	.store-btn:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 40px rgba(99, 102, 241, 0.5);
	}

	.store-btn.disabled {
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		color: rgba(241, 245, 249, 0.5);
		box-shadow: none;
		cursor: default;
		pointer-events: none;
	}

	.store-text {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.store-label {
		font-size: 0.7rem;
		opacity: 0.75;
		text-transform: uppercase;
		letter-spacing: 0.6px;
		margin-bottom: 0.15rem;
	}

	.store-name {
		font-size: 1.05rem;
		font-weight: 700;
	}

	/* ── Contact ──────────────────────────────── */
	#contact {
		padding: 7rem 2rem;
		text-align: center;
	}

	.contact-content {
		max-width: 560px;
		margin: 0 auto;
	}

	.contact-card {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		background: var(--card-bg);
		border: 1px solid var(--border-color);
		border-radius: 20px;
		padding: 1.5rem 1.75rem;
		text-decoration: none;
		transition: all 0.28s ease;
		text-align: left;
	}

	.contact-card:hover {
		background: var(--card-hover);
		border-color: var(--border-hover);
		transform: translateY(-3px);
		box-shadow: var(--shadow-md);
	}

	.contact-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 50px;
		height: 50px;
		min-width: 50px;
		background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
		border-radius: 14px;
		color: white;
		box-shadow: 0 4px 16px rgba(99, 102, 241, 0.35);
	}

	.contact-info {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		flex: 1;
	}

	.contact-label {
		font-size: 0.78rem;
		color: var(--text-muted);
		font-weight: 500;
	}

	.contact-email {
		font-size: 1rem;
		color: var(--primary-light);
		font-weight: 600;
	}

	.contact-arrow {
		color: var(--text-muted);
		flex-shrink: 0;
		transition: transform 0.2s ease, color 0.2s ease;
	}

	.contact-card:hover .contact-arrow {
		transform: translateX(4px);
		color: var(--primary-light);
	}

	/* ── Shared ───────────────────────────────── */
	.section-divider {
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(129, 140, 248, 0.18), transparent);
		margin: 0 auto;
		max-width: 900px;
	}

	/* ── Responsive ───────────────────────────── */
	@media (max-width: 1024px) {
		.hero-container {
			grid-template-columns: 1fr;
			text-align: center;
			gap: 3rem;
		}

		.hero-badge {
			margin-left: auto;
			margin-right: auto;
		}

		.hero-content p {
			margin-left: auto;
			margin-right: auto;
		}

		.hero-actions {
			justify-content: center;
		}

		.hero-pills {
			justify-content: center;
		}

		.hero-visual {
			order: -1;
		}
	}

	@media (max-width: 768px) {
		#hero {
			padding: 6.5rem 1.5rem 3rem;
			min-height: 100svh;
			gap: 2rem;
		}

		.scroll-indicator {
			display: none;
		}

		.phone-frame img {
			width: 170px;
		}

		.phone-glow {
			width: 220px;
			height: 220px;
		}

		#download,
		#contact {
			padding: 5rem 1.5rem;
		}

		.store-btn {
			min-width: 200px;
			justify-content: center;
		}

		.contact-card {
			text-align: left;
		}
	}

	@media (max-width: 480px) {
		.hero-content h1 {
			letter-spacing: -1px;
		}

		.store-buttons {
			flex-direction: column;
			align-items: center;
		}

		.store-btn {
			width: 100%;
			max-width: 300px;
		}

		.contact-email {
			font-size: 0.875rem;
			word-break: break-all;
		}
	}
</style>
