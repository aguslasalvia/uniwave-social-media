# ─── Auth ────────────────────────────────────────────────────────────────────
# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Either set a single DATABASE_URL...
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/uniwave?sslmode=disable
# ...or the discrete variables below (used when DATABASE_URL is empty).
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=uniwave
DB_SSLMODE=disable

# ─── MinIO (object storage for images) ───────────────────────────────────────
# Internal endpoint the server uses to talk to MinIO (host:port, no scheme).
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET=minioadmin
# Set to "true" if MinIO is served over HTTPS.
MINIO_USE_SSL=false
# Public base URL the mobile client can reach to load images.
# In dev this is usually your machine's LAN IP, e.g. http://192.168.1.10:9000
MINIO_PUBLIC_URL=http://localhost:9000

# ─── Mail (Gmail SMTP for activation emails) ─────────────────────────────────
MAIL_USERNAME=your-address@gmail.com
MAIL_APP_PASSWORD=your-gmail-app-password
# Path to the activation email HTML template (read at runtime, editable without
# rebuilding). Defaults to internal/templates/activation.html.
ACTIVATION_TEMPLATE_PATH=internal/templates/activation.html
